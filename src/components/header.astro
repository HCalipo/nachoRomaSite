---
// header.astro


const currentPath = Astro.url.pathname;
const isIndex = currentPath === "/";

const navLinks = [
  { href: "#hero",     label: "Inicio"   },
  { href: "#fechas",   label: "Fechas"   },
  { href: "#galeria",  label: "Galeria"  },
  { href: "#contacto", label: "Contacto" },
  { href: "/press-kit", label: "Press Kit" },
];
---

<!-- header pc -->
<header class="header-pc hidden md:flex fixed w-full top-0 z-50 bg-black/20 backdrop-blur-md py-1 px-6 md:px-12 border-b border-white/10">
  <div class="relative flex items-center justify-center w-full">
    <nav id="nav-menu" class="flex justify-center items-center gap-x-6 md:gap-x-14 relative preload-transitions">
      {navLinks.map(link => (
        <a href={isIndex ? link.href : `/${link.href}`} class="nav-item text-white/60 hover:text-white transition-colors relative after:content-[''] after:absolute after:-bottom-2 after:left-0 after:w-0 after:h-[2px] after:bg-white after:transition-all aria-[current=page]:text-white aria-[current=page]:after:w-full">
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<!-- header movil -->
<header class="header-movil md:hidden fixed top-0 left-0 w-full z-50 flex items-center px-5 py-4 overflow-hidden">
  <button id="m_hamburguesa_movil" aria-label="Abrir menú" aria-expanded="false" style="-webkit-tap-highlight-color: transparent;">
    <svg id="icon-open" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round">
      <line x1="3" y1="6"  x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
    <svg id="icon-close" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" style="display:none;">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6"  y1="6" x2="18" y2="18"/>
    </svg>
  </button>
</header>

<!-- panel movil -->
<div id="menu-panel" aria-hidden="true" style="
  position: fixed;
  top: 0; left: 0;
  width: 75vw;
  max-width: 200px;
  height: 100dvh;
  z-index: 49;
  background: rgba(0,0,0,0.97);
  border-right: 1px solid rgba(255,255,255,0.1);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 2.5rem;
  transform: translateX(-100%);
  visibility: hidden;
  pointer-events: none;
">
  <nav class="flex flex-col gap-8">
    {navLinks.map(link => (
      <a href={isIndex ? link.href : `/${link.href}`} class="nav-item-movil font-hanson-bold text-white/50 text-3l uppercase tracking-widest transition-colors hover:text-white active:text-white">
        {link.label}
      </a>
    ))}
  </nav>
</div>

<!-- fondo menu -->
<div id="menu-overlay" style="
  position: fixed;
  inset: 0;
  z-index: 48;
  background: rgba(0,0,0,0.5);
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
"></div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ScrollSmoother } from "gsap/ScrollSmoother";

  gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

  document.addEventListener("DOMContentLoaded", () => {

    const links               = document.querySelectorAll<HTMLAnchorElement>(".nav-item, .nav-item-movil");
    const headerPC            = document.querySelector(".header-pc");
    const headerMov           = document.querySelector<HTMLElement>(".header-movil");
    const panel               = document.getElementById("menu-panel") as HTMLElement;
    const overlay             = document.getElementById("menu-overlay") as HTMLElement;
    const m_hamburguesa_movil  = document.getElementById("m_hamburguesa_movil") as HTMLButtonElement;
    const iconOpen            = document.getElementById("icon-open") as HTMLElement;
    const iconClose           = document.getElementById("icon-close") as HTMLElement;
    let   isMenuAbierto       = false;

    //panel movil 
    function openMenu() {
      isMenuAbierto = true;
      panel.style.visibility    = "visible";
      panel.style.pointerEvents = "auto";
      overlay.style.visibility  = "visible";
      overlay.style.pointerEvents = "auto";
      m_hamburguesa_movil.setAttribute("aria-expanded", "true");
      panel.setAttribute("aria-hidden", "false");
      iconOpen.style.display  = "none";
      iconClose.style.display = "block";
      document.body.style.overflow = "hidden";

      gsap.to(panel,   { x: 0,   duration: 0.35, ease: "power3.out" });
      gsap.to(overlay, { opacity: 1, duration: 0.3 });
    }

    function closeMenu() {
      isMenuAbierto = false;
      m_hamburguesa_movil.setAttribute("aria-expanded", "false");
      panel.setAttribute("aria-hidden", "true");
      iconOpen.style.display  = "block";
      iconClose.style.display = "none";
      document.body.style.overflow = "";

      gsap.to(panel,   { x: "-100%", duration: 0.3, ease: "power3.in" });
      gsap.to(overlay, {
        opacity: 0,
        duration: 0.25,
        onComplete: () => {
          overlay.style.visibility    = "hidden";
          overlay.style.pointerEvents = "none";
          panel.style.visibility      = "hidden";
          panel.style.pointerEvents   = "none";
        }
      });
    }

    m_hamburguesa_movil.addEventListener("click", () => isMenuAbierto ? closeMenu() : openMenu());
    overlay.addEventListener("click", closeMenu);

    // navecación pc y movil
    links.forEach(link => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const targetId = link.getAttribute("href");
        if (!targetId?.startsWith("#")){
          window.location.href = targetId!;
          return;
        } 
        
        const targetSection = document.querySelector(targetId);
        if (!targetSection) return;

        if (isMenuAbierto) closeMenu();

        // Pequeño delay en móvil para que el panel cierre antes de saltar
        const delay = isMenuAbierto ? 400 : 0;
        setTimeout(() => {
          const smoother = ScrollSmoother.get();
          if (smoother) {
            smoother.scrollTo(targetSection, true, "top top");
          } else {
            targetSection.scrollIntoView({ behavior: "smooth" });
          }
        }, delay);
      });
    });

    
    let mm = gsap.matchMedia();
    //escritorio
    mm.add("(min-width: 768px)", () => {
      
      if (headerPC) {
        ScrollTrigger.create({
          start: "top top",
          end: "max",
          onUpdate: (self) => {
            if (self.direction === 1 && self.scroll() > 100) {
              gsap.to(headerPC, { yPercent: -100, duration: 0.3, ease: "power2.out" });
            } else {
              gsap.to(headerPC, { yPercent: 0, duration: 0.3, ease: "power2.out" });
            }
          }
        });
      }

      links.forEach(link => {
        const targetId = link.getAttribute("href");
        if (!targetId?.startsWith("#")) return;
        const targetSection = document.querySelector(targetId);
        if (targetSection) {
          ScrollTrigger.create({
            trigger: targetSection,
            start: "top center",
            end: "bottom center",
            onToggle: (self) => {
              if (self.isActive) {
                links.forEach(l => l.removeAttribute("aria-current"));
                link.setAttribute("aria-current", "page");
              }
            }
          });
        }
      });
    });
    //movil
    mm.add("(max-width: 767px)", () => {
      if (!headerMov) return;

      ScrollTrigger.create({
        start: "top top",
        end: "max",
        onUpdate: (self) => {
          if (isMenuAbierto) return; // no ocultar si el panel está abierto
          if (self.direction === 1 && self.scroll() > 40) {
            gsap.to(headerMov, { yPercent: -100, duration: 0.3, ease: "power2.out" });
          } else {
            gsap.to(headerMov, { yPercent: 0, duration: 0.3, ease: "power2.out" });
          }
        }
      });
    });
  });
</script>


