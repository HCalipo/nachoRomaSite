---

---
<section id="hero" class="relative w-full h-screen overflow-hidden bg-black">
  
  <img 
    src="/Foto_escritorio.webp" 
    class="capa-bg absolute inset-0 w-full h-full  object-cover object-center md:object-top z-0" 
    alt="Nacho con fondo" 
    fetchpriority="high"
    loading="eager"
    decoding="sync"
  />

  <div class="letras-nacho hidden md:flex absolute inset-0 items-center justify-center z-10">
    <h1 class="font-family-hanson font-bold text-white text-[10vw] leading-none text-center select-none flex gap-x-[8vw]">
      <span>NACHO</span>
      <span>ROMA</span>
    </h1>
  </div>


  <div class="logo-movil absolute right-4 top-[9%] md:hidden z-20">
      <img 
        src="/letrasNachoRoma.PNG"
        class="w-42 sm:w-40 object-contain" 
        alt="Logo Nacho Roma"
      />
  </div>

  <img 
    src="/Foto_escritorio_sinFondo.webp" 
    class="capa-nacho absolute inset-0 w-full h-full object-cover object-center md:object-top z-20" 
    alt="Nacho sin fondo" 
    fetchpriority="high"
    loading="eager"
    decoding="sync"
  />


  <div class="hero-overlay absolute inset-0 bg-black opacity-0 z-30 pointer-events-none"></div>

</section>
 
<script>
  import { gsap } from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    let mm = gsap.matchMedia();

    // Movil
    mm.add("(max-width: 767px)", () => {
      
      // entrada desde arriba
      gsap.from(".logo-movil", {
        y: -130,             
        opacity: 0,         
        duration: 1.5,      
        ease: "power3.out"  
      });

    });






    // PC
    mm.add("(min-width: 768px)", () => {
      
      const tl = gsap.timeline();

      //entrada de fondo y nacho
      tl.from([".capa-bg", ".capa-nacho"], {
          duration: 2,
          scale: 1.1,
          ease: "power3.inOut"
      });

      //entrada de las letras de abajo a arriba
      tl.from(".letras-nacho", {
          duration: 2,
          y: 100,
          scale: 0.8,
          opacity: 0,
          ease: "expo.Out"
      }, "-=1"); // 1s antes que la anterior
    });

  });
</script>
