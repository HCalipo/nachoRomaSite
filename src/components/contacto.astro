---
// src/components/contacto.astro
---
<section id="contacto" class="w-full relative py-24 px-8 md:px-16 bg-black border-t border-white/10 overflow-hidden">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row gap-16 items-start">
    
    <div class="w-full md:w-1/2 flex flex-col justify-center text-contacto">
      <h2 class="font-family-hanson text-white text-5xl md:text-7xl uppercase mb-6 leading-none select-none">
        Booking <br/> <span class="text-transparent" style="-webkit-text-stroke: 1px white;">& Info</span>
      </h2>
      <p class="texto-contacto text-white/60 mb-10 text-sm md:text-base tracking-wide max-w-sm">
        ¿Quieres reservar tu fecha? Escríbenos y nos pondremos en contacto contigo lo antes posible.
      </p>
      
      <a 
        href="https://www.instagram.com/nachoromadj" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="instagram-btn group flex items-center gap-4 w-fit cursor-pointer"
      >
        <div class="boton-ig w-14 h-14 rounded-full border border-white/30 
        flex items-center justify-center 
        transition-all duration-300 
        group-hover:border-white group-hover:bg-white text-white group-hover:text-black
        group-active:border-white group-active:bg-white text-white group-active:text-black">
          
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </div>
        <span class="font-family-hanson tracking-widest text-sm text-white/50 
                     group-hover:text-white group-active:text-white transition-colors duration-300"> 
          @nachoromadj
        </span>
      </a>
    </div>

    <div class="col-der w-full md:w-1/2">
      <form
        id="contacto-form"
        class="flex flex-col gap-8 w-full"
      >
        <!-- Honeypot — invisible para humanos, los bots lo rellenan -->
        <div style="position:absolute; left:-9999px; opacity:0; pointer-events:none;" aria-hidden="true">
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="grupo-input flex flex-col gap-2">
          <label for="nombre" class="font-family-hanson text-white/70 uppercase text-xs tracking-wider">Tu Nombre</label>
          <input type="text" id="nombre" name="nombre" autocomplete="off" required
            class="texto-contacto w-full bg-transparent border-b border-white/30 text-white py-3 focus:outline-none focus:border-white transition-colors placeholder:text-white/20"
            placeholder="Escribe tu nombre..." />
        </div>

        <div class="grupo-input flex flex-col gap-2">
          <label for="email" class="font-family-hanson text-white/70 uppercase text-xs tracking-wider">Tu Correo</label>
          <input type="email" id="email" name="email" autocomplete="off" required
            class="texto-contacto w-full bg-transparent border-b border-white/30 text-white py-3 focus:outline-none focus:border-white transition-colors placeholder:text-white/20"
            placeholder="ejemplo@correo.com" />
        </div>

        <div class="grupo-input flex flex-col gap-2">
          <label for="mensaje" class="font-family-hanson text-white/70 uppercase text-xs tracking-wider">Mensaje</label>
          <textarea id="mensaje" name="mensaje" autocomplete="off" rows="4" required
            class="texto-contacto w-full bg-transparent border-b border-white/30 text-white py-3 focus:outline-none focus:border-white transition-colors resize-none placeholder:text-white/20"
            placeholder="¿En qué puedo ayudarte?"></textarea>
        </div>

        <!-- Mensaje de feedback -->
        <p id="form-feedback" class="text-sm font-family-hanson tracking-wider hidden"></p>

        <button type="submit" id="boton-enviar"
          class="grupo-input boton-enviar w-full md:w-auto md:self-start mt-2
                font-family-hanson uppercase tracking-widest text-xs md:text-sm
                border border-white py-4 px-10 text-white
                hover:bg-white hover:text-black active:bg-white active:text-black
                transition-all duration-300 rounded-full cursor-pointer">
          Enviar Mensaje
        </button>
      </form>
    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {

    // 1. Forzar estado inicial visible para evitar el bug de móvil
    gsap.set(".boton-enviar", { opacity: 1, x: 0 });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#contacto",
        start: "top 70%",
        end: "center 60%",   // para bug en movil
        scrub: 0.6,
      }
    });

    
    tl.from(".text-contacto", {
      y: -40,
      opacity: 0,
      duration: 1,
      ease: "power3.out"
    })
  
    .from(".grupo-input", {
      x: 40,
      opacity: 0,
      ease: "power2.out",
      stagger: 0.15,
      duration: 0.8
    }, "-=0.5"); 

  });


  // Envío del formulario
  const form = document.getElementById('contacto-form') as HTMLFormElement;
  const boton = document.getElementById('boton-enviar') as HTMLButtonElement;
  const feedback = document.getElementById('form-feedback') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    boton.disabled = true;
    boton.textContent = 'Enviando...';
    feedback.className = 'text-sm font-family-hanson tracking-wider hidden';

    const data = {
      nombre:  (form.querySelector('#nombre') as HTMLInputElement).value,
      email:   (form.querySelector('#email')  as HTMLInputElement).value,
      mensaje: (form.querySelector('#mensaje') as HTMLTextAreaElement).value,
      website: (form.querySelector('[name="website"]') as HTMLInputElement).value,
    };

    try {
      const res = await fetch('/api/contacto', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const json = await res.json();

      if (json.ok) {
        feedback.textContent = 'Mensaje enviado. ¡Nos pondremos en contacto contigo pronto!';
        feedback.className = 'text-sm font-family-hanson tracking-wider text-white/60';
        form.reset();
      } else {
        feedback.textContent = json.error ?? 'Algo ha ido mal. Inténtalo de nuevo.';
        feedback.className = 'text-sm font-family-hanson tracking-wider text-red-400';
      }
    } catch {
      feedback.textContent = 'Error de conexión. Inténtalo de nuevo.';
      feedback.className = 'text-sm font-family-hanson tracking-wider text-red-400';
    } finally {
      boton.disabled = false;
      boton.textContent = 'Enviar Mensaje';
    }
  });


</script>