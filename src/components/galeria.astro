---
// src/components/galeria.astro
---

<section id="galeria" class="py-24 md:px-12 bg-black border-t border-white/10">
  <div class="max-w-7xl mx-auto">

    <h2 class="font-hanson text-white text-5xl md:text-7xl uppercase mb-12 leading-none px-6 md:px-0">
      <span class="text-transparent" style="-webkit-text-stroke: 1px white;">Galería</span>
    </h2>

    <div class="bento-grid px-6 md:px-0">

      <div class="bento-item cell-a relative overflow-hidden rounded-2xl bg-white/5 border border-white/10 group cursor-pointer" data-index="0">
        <img src="/Foto_escritorio.webp" alt="Nacho en directo" loading="lazy"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
      </div>

      <div class="bento-item cell-bc relative overflow-hidden rounded-2xl bg-white/5 border border-white/10 group cursor-pointer" data-index="1">
        <img src="/Foto_escritorio.webp" alt="Público" loading="lazy"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
      </div>

      <div class="bento-item cell-d relative overflow-hidden rounded-2xl bg-white/5 border border-white/10 group cursor-pointer" data-index="2">
        <img src="/Foto_escritorio.webp" alt="Mesa de mezclas" loading="lazy"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
      </div>

      <div class="bento-item cell-e relative overflow-hidden rounded-2xl bg-white/5 border border-white/10 group cursor-pointer" data-index="3">
        <img src="/Foto_escritorio.webp" alt="Detalle" loading="lazy"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
      </div>

      <div class="bento-item cell-f relative overflow-hidden rounded-2xl bg-white/5 border border-white/10 group cursor-pointer" data-index="4">
        <img src="/Foto_escritorio.webp" alt="Panorámica" loading="lazy"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
      </div>

      <div class="bento-item cell-g relative overflow-hidden rounded-2xl bg-white/5 border border-white/10 group cursor-pointer" data-index="5">
        <img src="/Foto_escritorio.webp" alt="Ambiente" loading="lazy"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
      </div>

    </div>
  </div>
</section>

<!-- LIGHTBOX  -->
<div id="lightbox" aria-hidden="true" style="
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0,0,0,0.93);
  display: flex;
  align-items: center;
  justify-content: center;
  visibility: hidden;
  opacity: 0;
  pointer-events: none;
">

  <!-- Fondo oscuro-->
  <div id="lb-backdrop" style="position:absolute;inset:0;"></div>

  <!-- Botón cerrar sup-d-->
  <button id="lb-close" aria-label="Cerrar" style="
    position: absolute;
    top: 16px; right: 16px;
    z-index: 10;
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(255,255,255,0.7);
    padding: 8px;
    line-height: 0;
    -webkit-tap-highlight-color: transparent;
  ">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <!-- Flecha izquierda -->
  <button id="lb-prev" aria-label="Anterior" style="
    position: absolute;
    left: 8px; top: 50%; transform: translateY(-50%);
    z-index: 10;
    background: rgba(255,255,255,0.08);
    border: none;
    border-radius: 50%;
    width: 44px; height: 44px;
    cursor: pointer;
    color: white;
    display: flex; align-items: center; justify-content: center;
    -webkit-tap-highlight-color: transparent;
  ">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
  </button>

  <!-- Imagen -->
  <div style="position:relative;
              z-index:5;
              display:flex; align-items:center; justify-content:center;
              width:100%; height:100%;
              padding:0 64px; 
              box-sizing:border-box;">
    <img id="lb-img" src="" alt="" style="
      max-width: 100%;
      max-height: 85vh;
      object-fit: contain;
      border-radius: 12px;
      user-select: none;
      -webkit-user-drag: none;
      display: block;
    " draggable="false" />
  </div>

  <!-- Flecha derecha -->
  <button id="lb-next" aria-label="Siguiente" style="
    position: absolute;
    right: 8px; top: 50%; transform: translateY(-50%);
    z-index: 10;
    background: rgba(255,255,255,0.08);
    border: none;
    border-radius: 50%;
    width: 44px; height: 44px;
    cursor: pointer;
    color: white;
    display: flex; align-items: center; justify-content: center;
    -webkit-tap-highlight-color: transparent;
  ">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </button>

  <!-- Puntos de navegación -->
  <div id="lb-dots" style="
    position: absolute;
    bottom: 20px;
    left: 0; right: 0;
    display: flex;
    justify-content: center;
    gap: 8px;
    z-index: 10;
  "></div>

</div>


<style>
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(3, 220px);
    gap: 10px;
  }

  .cell-a  { grid-column: 1 / 3; grid-row: 1 / 3; }
  .cell-bc { grid-column: 3 / 5; grid-row: 1; }
  .cell-d  { grid-column: 3;     grid-row: 2; }
  .cell-e  { grid-column: 4;     grid-row: 2; }
  .cell-f  { grid-column: 1 / 4; grid-row: 3; }
  .cell-g  { grid-column: 4;     grid-row: 3; }

  @media (max-width: 767px) {
    .bento-grid {
      grid-template-rows: repeat(3, 140px);
      gap: 7px;
    }
  }

  #lightbox.lb-visible {
    display: flex !important;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {

    // Animación entrada fotos 
    gsap.set(".bento-item", { opacity: 1, y: 0 });

    gsap.from(".bento-item", {
      y: 40,
      opacity: 0,
      duration: 0.7,
      stagger: { each: 0.1, from: "start" },
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#galeria",
        start: "top 75%",
        end: "center 60%",
        toggleActions: "play none none none"
      }
    });

    // Lightbox 
    const isMobile = () => window.innerWidth < 768;

    const lightbox = document.getElementById("lightbox") as HTMLElement;
    const lbImg    = document.getElementById("lb-img") as HTMLImageElement;
    const lbDots   = document.getElementById("lb-dots") as HTMLElement;
    const items    = document.querySelectorAll(".bento-item");

    const photos = Array.from(items).map(item => {
      const img = item.querySelector("img");
      return { src: img?.src ?? "", alt: img?.alt ?? "" };
    });

    let current = 0;
    let isOpen  = false;

    // Puntos de navegación
    photos.forEach(() => {
      const dot = document.createElement("div");
      dot.style.cssText = "width:6px;height:6px;border-radius:50%;background:white;opacity:0.3;transition:opacity 0.2s;flex-shrink:0;";
      lbDots.appendChild(dot);
    });

    function updateDots(index: number) {
      lbDots.querySelectorAll("div").forEach((dot, i) => {
        (dot as HTMLElement).style.opacity = i === index ? "1" : "0.3";
      });
    }

    function openLightbox(index: number) {
      current = index;
      lbImg.src = photos[current].src;
      lbImg.alt = photos[current].alt;
      updateDots(current);

      //Hacer visible antes de animar
      lightbox.style.visibility = "visible";
      lightbox.style.pointerEvents = "auto";
      lightbox.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      isOpen = true;

      gsap.fromTo(lightbox,
        { opacity: 0 },
        { opacity: 1, duration: 0.3, ease: "power2.out" }
      );
      gsap.fromTo(lbImg,
        { scale: 0.9, opacity: 0 },
        { scale: 1, opacity: 1, duration: 0.35, ease: "power3.out" }
      );
    }

    function closeLightbox() {
      gsap.to(lightbox, {
        opacity: 0,
        duration: 0.25,
        ease: "power2.in",
        onComplete: () => {
          lightbox.style.visibility = "hidden";
          lightbox.style.pointerEvents = "none";
          lightbox.setAttribute("aria-hidden", "true");
          document.body.style.overflow = "";
          isOpen = false;
        }
      });
    }

    function navigate(dir: number) {
      const next   = (current + dir + photos.length) % photos.length;
      const exitX  = dir * -80;
      const enterX = dir * 80;

      gsap.to(lbImg, {
        x: exitX,
        opacity: 0,
        duration: 0.18,
        ease: "power2.in",
        onComplete: () => {
          current   = next;
          lbImg.src = photos[current].src;
          lbImg.alt = photos[current].alt;
          updateDots(current);
          gsap.fromTo(lbImg,
            { x: enterX, opacity: 0 },
            { x: 0, opacity: 1, duration: 0.22, ease: "power2.out" }
          );
        }
      });
    }

    //abir (implementación solo en el telefono)
    items.forEach(item => {
      item.addEventListener("click", () => {
        if (!isMobile()) return;
        const index = parseInt(item.getAttribute("data-index") ?? "0");
        openLightbox(index);
      });
    });

    // Cerrar con X
    document.getElementById("lb-close")?.addEventListener("click", (e) => {
      e.stopPropagation();
      closeLightbox();
    });

    // Flechas
    document.getElementById("lb-prev")?.addEventListener("click", (e) => {
      e.stopPropagation();
      navigate(-1);
    });
    document.getElementById("lb-next")?.addEventListener("click", (e) => {
      e.stopPropagation();
      navigate(1);
    });

    // Teclado
    document.addEventListener("keydown", (e) => {
      if (!isOpen) return;
      if (e.key === "ArrowLeft")  navigate(-1);
      if (e.key === "ArrowRight") navigate(1);
      if (e.key === "Escape")     closeLightbox();
    });

    // Swipe táctil
    let touchStartX = 0;
    let touchDeltaX = 0;
    let isSwiping   = false;

    lightbox.addEventListener("touchstart", (e) => {
      const target = e.target as HTMLElement;
      if (target.closest("button")) return;
      touchStartX = e.touches[0].clientX;
      touchDeltaX = 0;
      isSwiping   = true;
    }, { passive: true });

    lightbox.addEventListener("touchmove", (e) => {
      if (!isSwiping) return;
      touchDeltaX = e.touches[0].clientX - touchStartX;
      gsap.set(lbImg, { x: touchDeltaX * 0.35 });
    }, { passive: true });

    lightbox.addEventListener("touchend", (e) => {
      const target = e.target as HTMLElement;
      if (target.closest("button")) return;

      if (!isSwiping) return;
      isSwiping = false;

      if (Math.abs(touchDeltaX) > 50) {
        navigate(touchDeltaX < 0 ? 1 : -1);
      } else if (Math.abs(touchDeltaX) < 10) {
        if (!target.closest("#lb-img")) {
          closeLightbox();
        }
      } else {
        // Swipe corto, volver al centro
        gsap.to(lbImg, { x: 0, duration: 0.2, ease: "power2.out" });
      }

      touchDeltaX = 0;
    });

  });
</script>