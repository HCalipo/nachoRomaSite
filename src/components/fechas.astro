---
const API_KEY = import.meta.env.GOOGLE_SHEETS_API_KEY;
const SHEET_ID = import.meta.env.SPREADSHEET_ID;

const RANGE = "A2:C"; 

const url = `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/${RANGE}?key=${API_KEY}`;

interface Evento {
  fecha: string;
  ciudad: string;
  local: string;
}

let eventos: Evento[] = [];

try {
  const response = await fetch(url);
  const data = await response.json();
  
  // ESTO ES NUEVO: Te imprimirá en la terminal de tu ordenador lo que dice Google
  console.log("Respuesta de Google:", data);

  // Si la petición falla, mostramos el motivo exacto
  if (!response.ok) {
    console.error("Error de la API de Google:", data.error?.message);
  }
  
  if (data.values) {
    eventos = data.values.map((fila: string[]) => ({
      fecha: fila[0] || "",  
      ciudad: fila[1] || "",  
      local: fila[2] || ""    
    }));
  }
} catch (error) {
  console.error("Hubo un error de red al coger las fechas:", error);
}
---

<section id="fechas" class="w-full relative py-24 px-8 md:px-16">
  
  <div class="max-w-5xl mx-auto">
    
    <div class="flex flex-col">
      {eventos.map((eventos) => (
        // Mantenemos el grid-cols-3 en todas las pantallas. Solo variamos el padding (py-3 en móvil, py-6 en ordenador)
        <div class="group grid grid-cols-3 items-center py-3 border-b border-white/20 transition-colors hover:border-white/50 md:py-6">
          
          <span class="font-hanson text-white text-sm md:text-xl uppercase text-left tracking-wider">
            {eventos.fecha}
          </span>
          
          <span class="text-white/70 text-xs md:text-lg uppercase tracking-widest text-center">
            {eventos.ciudad}
          </span>
          
          <span class="text-white/60 text-[10px] sm:text-xs md:text-base uppercase tracking-widest text-right">
            {eventos.local}
          </span>
          
        </div>
      ))}
    </div>

  </div>
</section>