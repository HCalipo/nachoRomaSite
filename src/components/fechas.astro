---
const eventos = [
  { fecha: "15/06", ciudad: "Madrid", local: "Sala Sol" },
  { fecha: "22/06", ciudad: "Barcelona", local: "Razzmatazz" },
  { fecha: "05/07", ciudad: "Valencia", local: "Marina Sur" },
  { fecha: "18/08", ciudad: "Alicante", local: "Plaza de Toros" }
];
---

<section id="fechas" class="w-full relative py-24 px-8 md:px-16">
  
  <div class="max-w-5xl mx-auto">
    
    <div class="flex flex-col">
      {eventos.map((eventos) => (
        <div class="group grid grid-cols-3 items-center py-3 border-b border-white/20 transition-colors hover:border-white/50 md:py-6">
          
          <span class="font-hanson text-white text-sm md:text-xl uppercase text-left tracking-wider">
            {eventos.fecha}
          </span>
          
          <span class="text-white/70 text-xs md:text-lg uppercase tracking-widest text-center">
            {eventos.ciudad}
          </span>
          
          <span class="text-white/60 text-[10px] sm:text-xs md:text-base uppercase tracking-widest text-right">
            {eventos.local}
          </span>
          
        </div>
      ))}
    </div>

  </div>
</section>